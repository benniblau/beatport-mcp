# Required
BEATPORT_USERNAME=
BEATPORT_PASSWORD=
BEATPORT_BASE_URL=https://api.beatport.com/v4

# Optional — pre-seed tokens to skip login on first start
BEATPORT_ACCESS_TOKEN=
BEATPORT_REFRESH_TOKEN=
BEATPORT_TOKEN_EXPIRES_AT=

# Optional — MCP server bind address
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Optional — bearer token for external access (if set, all requests must include Authorization: Bearer <token>)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=
